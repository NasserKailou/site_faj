Options -Indexes
ServerSignature Off

# ─── Réécriture d'URL ──────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Rediriger vers HTTPS en production
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Supprimer le www
    # RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    # RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

    # ── Supprimer l'extension .php (URLs propres) ─────────────────────────
    # Si la requête n'est pas un fichier réel, ni un dossier réel
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f

    # Pages principales sans préfixe
    RewriteRule ^(a-propos|projets|actualites|contact|don|equipe|don-succes|don-annule|conditions-generales|politique-confidentialite|faq)$ pages/$1.php [L,QSA]

    # Admin sans extension
    RewriteRule ^admin/?$                    admin/index.php          [L,QSA]
    RewriteRule ^admin/login$                admin/login.php          [L,QSA]
    RewriteRule ^admin/logout$               admin/logout.php         [L,QSA]
    RewriteRule ^admin/dashboard$            admin/dashboard.php      [L,QSA]
    RewriteRule ^admin/dons/?$               admin/dons/liste.php     [L,QSA]
    RewriteRule ^admin/projets/?$            admin/projets/liste.php  [L,QSA]
    RewriteRule ^admin/actualites/?$         admin/actualites/liste.php [L,QSA]
    RewriteRule ^admin/equipe/?$             admin/equipe/liste.php   [L,QSA]
    RewriteRule ^admin/contacts/?$           admin/contacts/liste.php [L,QSA]
    RewriteRule ^admin/parametres$           admin/parametres.php     [L,QSA]

    # Projets avec slug
    RewriteRule ^projets/([a-z0-9-]+)$       pages/projet-detail.php?slug=$1 [L,QSA]

    # Actualités avec slug
    RewriteRule ^actualites/([a-z0-9-]+)$    pages/actualite-detail.php?slug=$1 [L,QSA]

    # Rediriger les URL .php vers URL propre (éviter le doublon)
    RewriteCond %{THE_REQUEST} /pages/([^/]+)\.php [NC]
    RewriteRule ^ /%1? [R=301,L]

    RewriteCond %{THE_REQUEST} /admin/([^/]+)\.php [NC]
    RewriteRule ^ /admin/%1? [R=301,L]
</IfModule>

# ─── Protection des fichiers sensibles ──────────────────────────────────────
<FilesMatch "(config\.php|\.env|database\.sql|.*\.sqlite|.*\.log)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Bloquer l'accès aux répertoires sensibles
<IfModule mod_rewrite.c>
    RewriteRule ^includes/        - [F,L]
    RewriteRule ^admin/includes/  - [F,L]
    RewriteRule ^logs/            - [F,L]
    RewriteRule ^\.git/           - [F,L]
</IfModule>

# ─── Headers de sécurité HTTP ────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options   "nosniff"
    Header always set X-Frame-Options          "SAMEORIGIN"
    Header always set X-XSS-Protection         "1; mode=block"
    Header always set Referrer-Policy          "strict-origin-when-cross-origin"
    Header always set Permissions-Policy       "geolocation=(), microphone=(), camera=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Content-Security-Policy  "default-src 'self' https: data: 'unsafe-inline' 'unsafe-eval'; img-src 'self' https: data: blob:; font-src 'self' https: data:;"

    # Supprimer les headers révélateurs
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# ─── Compression GZIP ────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ─── Cache des ressources statiques ─────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg          "access plus 1 month"
    ExpiresByType image/jpeg         "access plus 1 month"
    ExpiresByType image/png          "access plus 1 month"
    ExpiresByType image/webp         "access plus 1 month"
    ExpiresByType image/svg+xml      "access plus 1 month"
    ExpiresByType image/x-icon       "access plus 1 year"
    ExpiresByType text/css           "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType application/font-woff  "access plus 1 month"
    ExpiresByType application/font-woff2 "access plus 1 month"
</IfModule>

# ─── Pages d'erreur personnalisées ──────────────────────────────────────────
ErrorDocument 404 /pages/404.php
ErrorDocument 403 /pages/403.php
ErrorDocument 500 /pages/500.php

# ─── Protection contre les injections courantes ─────────────────────────────
<IfModule mod_rewrite.c>
    # Bloquer les tentatives d'injection SQL dans l'URL
    RewriteCond %{QUERY_STRING} (union.*select|select.*from|insert.*into|drop.*table) [NC]
    RewriteRule .* - [F,L]

    # Bloquer XSS dans l'URL
    RewriteCond %{QUERY_STRING} (<script|javascript:|vbscript:|onload=|onerror=) [NC]
    RewriteRule .* - [F,L]

    # Bloquer les traversées de répertoire
    RewriteCond %{REQUEST_URI} \.\./
    RewriteRule .* - [F,L]
</IfModule>

# ─── Limiter la taille des uploads ──────────────────────────────────────────
<IfModule mod_php8.c>
    php_value upload_max_filesize 5M
    php_value post_max_size 8M
    php_value max_execution_time 60
    php_value memory_limit 128M
</IfModule>
