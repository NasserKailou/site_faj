Options -Indexes
ServerSignature Off

# ─── Réécriture d'URL ──────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # IMPORTANT : adapter RewriteBase selon l'environnement
    # - En local XAMPP sous /site_faj/  → RewriteBase /site_faj/
    # - En production (domaine racine)  → RewriteBase /
    RewriteBase /site_faj/

    # ── 1. Bloquer l'accès aux répertoires SENSIBLES (avant tout) ─────────
    RewriteRule ^includes/           - [F,L]
    RewriteRule ^admin/includes/     - [F,L]
    RewriteRule ^logs/               - [F,L]
    RewriteRule ^\.git/              - [F,L]

    # ── 2. Bloquer les injections SQL dans l'URL ──────────────────────────
    RewriteCond %{QUERY_STRING} (union.*select|select.*from|insert.*into|drop.*table) [NC]
    RewriteRule .* - [F,L]

    # ── 3. Bloquer XSS dans l'URL ─────────────────────────────────────────
    RewriteCond %{QUERY_STRING} (<script|javascript:|vbscript:|onload=|onerror=) [NC]
    RewriteRule .* - [F,L]

    # ── 4. Bloquer les traversées de répertoire ───────────────────────────
    RewriteCond %{REQUEST_URI} \.\./ [NC]
    RewriteRule .* - [F,L]

    # ── 5. Servir les assets statiques admin (CSS, JS uniquement) ─────────
    # Permet admin/assets/css/admin.css, admin/assets/js/*.js, etc.
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteCond %{REQUEST_URI} ^.*/admin/assets/
    RewriteRule ^ - [L]

    # ── 6. Servir les fichiers statiques publics (CSS, JS, images, uploads)─
    # SAUF tout ce qui est dans admin/ ou pages/ (géré par les routes)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteCond %{REQUEST_URI} !^.*/admin/
    RewriteCond %{REQUEST_URI} !^.*/pages/
    RewriteRule ^ - [L]

    # ── 7. Routes Admin — sous-pages avec paramètres ──────────────────────
    RewriteRule ^admin/dons/detail/?$            admin/dons/detail.php        [L,QSA]
    RewriteRule ^admin/dons/export/?$            admin/dons/export.php        [L,QSA]

    # ── 8. Routes Admin — listes (DOIVENT passer avant la vérif répertoire)─
    RewriteRule ^admin/?$                        admin/index.php              [L,QSA]
    RewriteRule ^admin/login/?$                  admin/login.php              [L,QSA]
    RewriteRule ^admin/logout/?$                 admin/logout.php             [L,QSA]
    RewriteRule ^admin/dashboard/?$              admin/dashboard.php          [L,QSA]
    RewriteRule ^admin/parametres/?$             admin/parametres.php         [L,QSA]
    RewriteRule ^admin/dons/?$                   admin/dons/liste.php         [L,QSA]
    RewriteRule ^admin/projets/?$                admin/projets/liste.php      [L,QSA]
    RewriteRule ^admin/actualites/?$             admin/actualites/liste.php   [L,QSA]
    RewriteRule ^admin/equipe/?$                 admin/equipe/liste.php       [L,QSA]
    RewriteRule ^admin/temoignages/?$            admin/temoignages/liste.php  [L,QSA]
    RewriteRule ^admin/partenaires/?$            admin/partenaires/liste.php  [L,QSA]
    RewriteRule ^admin/contacts/?$               admin/contacts/liste.php     [L,QSA]
    RewriteRule ^admin/newsletter/?$             admin/newsletter/liste.php   [L,QSA]
    RewriteRule ^admin/admins/?$                 admin/admins/liste.php       [L,QSA]

    # ── 9. Routes pages publiques ─────────────────────────────────────────
    RewriteRule ^$                               index.php                           [L,QSA]
    RewriteRule ^a-propos/?$                     pages/a-propos.php                  [L,QSA]
    RewriteRule ^projets/?$                      pages/projets.php                   [L,QSA]
    RewriteRule ^actualites/?$                   pages/actualites.php                [L,QSA]
    RewriteRule ^contact/?$                      pages/contact.php                   [L,QSA]
    RewriteRule ^don/?$                          pages/don.php                       [L,QSA]
    RewriteRule ^equipe/?$                       pages/equipe.php                    [L,QSA]
    RewriteRule ^don-succes/?$                   pages/don-succes.php                [L,QSA]
    RewriteRule ^don-annule/?$                   pages/don-annule.php                [L,QSA]
    RewriteRule ^conditions-generales/?$         pages/conditions-generales.php      [L,QSA]
    RewriteRule ^politique-confidentialite/?$    pages/politique-confidentialite.php [L,QSA]
    RewriteRule ^mentions-legales/?$             pages/mentions-legales.php          [L,QSA]
    RewriteRule ^faq/?$                          pages/faq.php                       [L,QSA]

    # ── 10. Routes avec slug dynamique ────────────────────────────────────
    RewriteRule ^projets/([a-z0-9-]+)/?$         pages/projet-detail.php?slug=$1    [L,QSA]
    RewriteRule ^actualites/([a-z0-9-]+)/?$      pages/actualite-detail.php?slug=$1 [L,QSA]

    # ── 11. Routes API (garder les .php pour les appels AJAX) ─────────────
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteCond %{REQUEST_URI} ^.*/api/
    RewriteRule ^ - [L]

    # ── 12. Tout le reste : fichiers physiques réels (fallback) ───────────
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # IMPORTANT : On NE sert PAS les répertoires physiques (cela causerait des 403)
    # Les dossiers admin/projets/, admin/equipe/ etc. sont tous gérés par les routes ci-dessus

</IfModule>

# ─── Protection des fichiers sensibles ──────────────────────────────────────
<FilesMatch "(config\.php|\.env|database\.sql|.*\.sqlite|.*\.log)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ─── Headers de sécurité HTTP ────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options   "nosniff"
    Header always set X-Frame-Options          "SAMEORIGIN"
    Header always set X-XSS-Protection         "1; mode=block"
    Header always set Referrer-Policy          "strict-origin-when-cross-origin"
    Header always set Permissions-Policy       "geolocation=(), microphone=(), camera=()"
    # Désactivé en local HTTP — activer en production HTTPS uniquement :
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Content-Security-Policy  "default-src 'self' https: data: 'unsafe-inline' 'unsafe-eval'; img-src 'self' https: data: blob:; font-src 'self' https: data:;"
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# ─── Compression GZIP ────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ─── Cache des ressources statiques ─────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg          "access plus 1 month"
    ExpiresByType image/jpeg         "access plus 1 month"
    ExpiresByType image/png          "access plus 1 month"
    ExpiresByType image/webp         "access plus 1 month"
    ExpiresByType image/svg+xml      "access plus 1 month"
    ExpiresByType image/x-icon       "access plus 1 year"
    ExpiresByType text/css           "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType application/font-woff  "access plus 1 month"
    ExpiresByType application/font-woff2 "access plus 1 month"
</IfModule>

# ─── Pages d'erreur personnalisées ──────────────────────────────────────────
ErrorDocument 404 /site_faj/pages/404.php
ErrorDocument 403 /site_faj/pages/403.php
ErrorDocument 500 /site_faj/pages/500.php

# ─── Limiter la taille des uploads ──────────────────────────────────────────
<IfModule mod_php8.c>
    php_value upload_max_filesize 5M
    php_value post_max_size 8M
    php_value max_execution_time 60
    php_value memory_limit 128M
</IfModule>
